# Linear
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_TEAM_KEY=HMC
LINEAR_PROJECT_NAME=hm
LINEAR_WEBHOOK_SECRET=replace_me_openssl_rand_hex_32

# TickTick (register at https://developer.ticktick.com/manage)
TICKTICK_CLIENT_ID=xxxxxxxxxxxxxxxx
TICKTICK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TICKTICK_REDIRECT_URI=https://lt-sync.example.com/oauth/ticktick/callback
TICKTICK_LIST_ID=69cd04eb8f088eaeff7fb755
TICKTICK_DEFAULT_TZ=Europe/Moscow

# Multi-team sync (optional). JSON list of pairs; when unset the legacy
# LINEAR_TEAM_KEY / LINEAR_PROJECT_NAME / TICKTICK_LIST_ID above form one pair.
# project_name omitted/null → sync the whole team.
# SYNC_PAIRS=[{"team_key":"HMC","ticktick_list_id":"69cd04eb8f088eaeff7fb755","project_name":"hm"},{"team_key":"w3a","ticktick_list_id":"6a2be1928f08a3d9c9238a4a"}]

# Pushover (optional — for token-expiry / sync-error alerts)
# PUSHOVER_TOKEN=
# PUSHOVER_USER=

# Service / DB
DATABASE_URL=sqlite+aiosqlite:///./data/state.db
POLL_INTERVAL_SEC=180
LINEAR_BACKFILL_INTERVAL_SEC=3600
TOKEN_CHECK_INTERVAL_SEC=86400
ECHO_WINDOW_SEC=30
BACKFILL_ON_START=true
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://lt-sync.example.com
